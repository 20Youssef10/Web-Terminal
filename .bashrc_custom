# Inherit standard bashrc
if [ -f ~/.bashrc ]; then
    source ~/.bashrc
fi

# Ubuntu style prompt
export PS1='\[\033[01;32m\]\u@ubuntu\[\033[00m\]:\[\033[01;34m\]\w\[\033[00m\]\$ '

# Aliases
alias ls='ls --color=auto'
alias grep='grep --color=auto'
alias ll='ls -alF'
alias la='ls -A'
alias l='ls -CF'
alias python='python3'
alias pip='python3 -m pip'

# Ensure local bin is in PATH for zstd etc
export PATH="$HOME/.local/bin:$PATH"

echo -e "\e[1;32mWelcome to Ubuntu Web Terminal!\e[0m"
echo -e "\e[38;5;240mFeatures: Background processes, full TUI support (vim, nano, htop), SSH/SCP, and real-time streaming.\e[0m"
echo -e "\e[38;5;75mProxy:\e[0m Access local ports via the 'Open Port' button above."
echo ""
